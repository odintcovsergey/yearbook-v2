# Шаблон окружения yearbook-v2. Скопируйте в .env.local и заполните.
# Реальные значения НЕ коммитить. Прод-значения — в /srv/yearbook/shared/.env.production
# на сервере Timeweb (см. knowledge/RECOVERY.md).
#
# После переезда на Timeweb (22.06.2026): БД — self-host PostgREST поверх Managed
# Postgres Timeweb, хранилище — S3 Timeweb. Клиент supabase-js остался, но смотрит
# на наш PostgREST-endpoint, а не на Supabase-cloud.

# ── БД / PostgREST (Timeweb self-host) ───────────────────────────────────────
# URL PostgREST-эндпоинта (НЕ Supabase-cloud). supabase-js ходит сюда.
NEXT_PUBLIC_SUPABASE_URL=https://<postgrest-endpoint>
# Ключи доступа PostgREST (роль service_role обходит RLS — только сервер).
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-jwt>

# ── Аутентификация ───────────────────────────────────────────────────────────
# Секрет подписи JWT-куки auth_token (обязателен).
JWT_SECRET=<длинный-случайный-секрет>
# Bootstrap-пароль для первичной настройки (/admin setup). Не для рантайма.
ADMIN_SECRET=<пароль-минимум-20-символов>

# ── Хранилище: Timeweb S3 (боевое) ───────────────────────────────────────────
# КРИТИЧНО: в проде ОБЯЗАТЕЛЬНО timeweb. При другом значении приложение в
# production падает на старте (instrumentation.ts), чтобы не уехать в мёртвое
# Supabase/Yandex-хранилище. Дефолт при отсутствии = supabase (только dev/test).
STORAGE_BACKEND=timeweb
TWC_S3_ENDPOINT=https://s3.twcstorage.ru
TWC_S3_REGION=ru-1
TWC_S3_BUCKET=<id-бакета>
TWC_S3_ACCESS_KEY_ID=<twc-access-key>
TWC_S3_SECRET_ACCESS_KEY=<twc-secret-key>

# ── Хранилище: Yandex Object Storage (LEGACY-fallback) ───────────────────────
# Используется ТОЛЬКО если STORAGE_BACKEND != timeweb (допереездная страховка).
# В проде не нужны; ключи формата `yc:` в БД роутятся в Timeweb, не в YC.
YC_ACCESS_KEY_ID=<yc-access-key>
YC_SECRET_ACCESS_KEY=<yc-secret-key>
YC_BUCKET_NAME=yearbook-photos

# ── Чистильщик истёкших экспортов/выдачи (/api/cleanup) ──────────────────────
# Bearer-токен для POST /api/cleanup (чистка album_exports/delivery_files по TTL).
# Сейчас в проде не задан → эндпоинт отключён (см. audit-legacy-tails.md).
CLEANUP_SECRET=<случайный-токен>

# ── Опциональное ─────────────────────────────────────────────────────────────
# AI-функции (если включены).
ANTHROPIC_API_KEY=<anthropic-key>
# Тенант по умолчанию для некоторых служебных путей.
DEFAULT_TENANT_ID=<uuid-тенанта>
# Порог разворотов, выше которого экспорт уходит в фоновую очередь.
EXPORT_SYNC_SPREAD_THRESHOLD=30
