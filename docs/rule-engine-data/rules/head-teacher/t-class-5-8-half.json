{
  "id": "t-class-5-8-half",
  "family_id": "head-teacher",
  "family_version": "1.0",
  "priority": 100,
  "display_name": "Классрук + 5-8 предметников, полкласса справа",
  "description": "subjects=5..8: F-Head-LargeGrid слева (8 слотов, лишние балансируются), G-HalfClass справа при наличии полкласса. Возможен alt-variant с переносом сетки на правую страницу (F-Head-WithPhoto + G-Teachers-3x3) — партнёр переключает в редакторе.",
  "when": {
    "subjects_count": { "between": [5, 8] },
    "common_photos.half_class.count": { "gte": 2 },
    "print_type": "layflat"
  },
  "produces": {
    "type": "spread",
    "left_master": "F-Head-LargeGrid",
    "right_master": "G-HalfClass"
  },
  "bind": {
    "F-Head-LargeGrid": {
      "headteacherphoto": "input.head_teacher.photo",
      "headteachername": "input.head_teacher.name",
      "headteacherrole": "input.head_teacher.role",
      "headtextframe": "input.head_teacher.text",
      "teacherphoto_{i}": {
        "template": "input.subjects[{i}-1].photo",
        "params": { "i": { "range": [1, "subjects_count"] } }
      },
      "teachername_{i}": {
        "template": "input.subjects[{i}-1].name",
        "params": { "i": { "range": [1, "subjects_count"] } }
      },
      "teacherrole_{i}": {
        "template": "input.subjects[{i}-1].role",
        "params": { "i": { "range": [1, "subjects_count"] } }
      }
    },
    "G-HalfClass": {
      "halfphoto_1": "input.common_photos.half_class[0]",
      "halfphoto_2": "input.common_photos.half_class[1]"
    }
  },
  "consumes": {
    "common_photos": { "half_class": 2 }
  },
  "balance": { "placeholder_centering": true }
}
