{
  "id": "common-mandatory-light-hard-page-4-sixth-six-e9-opt-sixth-six",
  "family_id": "common-section",
  "family_version": "1.0",
  "priority": 233,
  "display_name": "Общий раздел (обязательный): Лайт плотные, страница 4 — коллаж 12 фото 1/6 (опция sixth-six)",
  "description": "Авто-сгенерировано из docs/templates/album-structure-matrix.json entry #9 (РЭ.20.6.3). Матрица: light × hard, students [{\"min\":19,\"max\":21},{\"min\":31,\"max\":33}]. mandatory_section_pages[4] = sixth_six. Эта опция выбрана из alternative по приоритету наличия фотоматериала.",
  "when": {
    "preset_density": "light",
    "preset_sheet_type": "hard",
    "students_count": {
      "between": [
        19,
        33
      ]
    },
    "mandatory_section.current_index": 4,
    "common_photos.sixth.count": {
      "gte": 12
    }
  },
  "produces": {
    "type": "spread",
    "left_master": "J-Collage-6",
    "right_master": "J-Collage-6"
  },
  "bind": {
    "left_master": {
      "collagephoto_{i}": {
        "template": "input.common_photos.sixth[$consumed_sixth + {i} - 1]",
        "params": {
          "i": {
            "range": [
              1,
              6
            ]
          }
        }
      }
    },
    "right_master": {
      "collagephoto_{i}": {
        "template": "input.common_photos.sixth[$consumed_sixth + 6 + {i} - 1]",
        "params": {
          "i": {
            "range": [
              1,
              6
            ]
          }
        }
      }
    }
  },
  "consumes": {
    "common_photos": {
      "sixth": 12
    },
    "pages": 2,
    "mandatory_section": {
      "pages": 1
    }
  }
}
