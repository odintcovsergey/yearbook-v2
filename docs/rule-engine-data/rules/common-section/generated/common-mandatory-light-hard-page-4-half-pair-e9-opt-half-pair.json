{
  "id": "common-mandatory-light-hard-page-4-half-pair-e9-opt-half-pair",
  "family_id": "common-section",
  "family_version": "1.0",
  "priority": 232,
  "display_name": "Общий раздел (обязательный): Лайт плотные, страница 4 — пара 1/2 класса (опция half-pair)",
  "description": "Авто-сгенерировано из docs/templates/album-structure-matrix.json entry #9 (РЭ.20.6.3). Матрица: light × hard, students [{\"min\":19,\"max\":21},{\"min\":31,\"max\":33}]. mandatory_section_pages[4] = half_pair. Эта опция выбрана из alternative по приоритету наличия фотоматериала.",
  "when": {
    "preset_density": "light",
    "preset_sheet_type": "hard",
    "students_count": {
      "between": [
        19,
        33
      ]
    },
    "mandatory_section.current_index": 4,
    "common_photos.half_class.count": {
      "gte": 4
    }
  },
  "produces": {
    "type": "spread",
    "left_master": "J-Half",
    "right_master": "J-Half"
  },
  "bind": {
    "left_master": {
      "halfphoto_1": "input.common_photos.half_class[$consumed_half_class]",
      "halfphoto_2": "input.common_photos.half_class[$consumed_half_class + 1]"
    },
    "right_master": {
      "halfphoto_1": "input.common_photos.half_class[$consumed_half_class + 2]",
      "halfphoto_2": "input.common_photos.half_class[$consumed_half_class + 3]"
    }
  },
  "consumes": {
    "common_photos": {
      "half_class": 4
    },
    "pages": 2,
    "mandatory_section": {
      "pages": 1
    }
  }
}
