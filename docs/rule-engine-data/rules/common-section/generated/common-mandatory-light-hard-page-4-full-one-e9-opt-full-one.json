{
  "id": "common-mandatory-light-hard-page-4-full-one-e9-opt-full-one",
  "family_id": "common-section",
  "family_version": "1.0",
  "priority": 231,
  "display_name": "Общий раздел (обязательный): Лайт плотные, страница 4 — 2 общих фото класса (опция full-one)",
  "description": "Авто-сгенерировано из docs/templates/album-structure-matrix.json entry #9 (РЭ.20.6.3). Матрица: light × hard, students [{\"min\":19,\"max\":21},{\"min\":31,\"max\":33}]. mandatory_section_pages[4] = full_one. Эта опция выбрана из alternative по приоритету наличия фотоматериала.",
  "when": {
    "preset_density": "light",
    "preset_sheet_type": "hard",
    "students_count": {
      "between": [
        19,
        33
      ]
    },
    "mandatory_section.current_index": 4,
    "common_photos.full_class.count": {
      "gte": 2
    }
  },
  "produces": {
    "type": "spread",
    "left_master": "J-Full",
    "right_master": "J-Full"
  },
  "bind": {
    "left_master": {
      "classphotoframe": "input.common_photos.full_class[$consumed_full_class]"
    },
    "right_master": {
      "classphotoframe": "input.common_photos.full_class[$consumed_full_class + 1]"
    }
  },
  "consumes": {
    "common_photos": {
      "full_class": 2
    },
    "pages": 2,
    "mandatory_section": {
      "pages": 1
    }
  }
}
