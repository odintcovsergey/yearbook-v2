{
  "id": "common-mandatory-mini-soft-page-0-half-pair-e3",
  "family_id": "common-section",
  "family_version": "1.0",
  "priority": 232,
  "display_name": "Общий раздел (обязательный): Мини мягкие, страница 0 — пара 1/2 класса",
  "description": "Авто-сгенерировано из docs/templates/album-structure-matrix.json entry #3 (РЭ.20.6.3). Матрица: mini × soft, students [{\"min\":1,\"max\":24}]. mandatory_section_pages[0] = half_pair.",
  "when": {
    "preset_density": "mini",
    "preset_sheet_type": "soft",
    "students_count": {
      "between": [
        1,
        24
      ]
    },
    "mandatory_section.current_index": 0,
    "common_photos.half_class.count": {
      "gte": 4
    }
  },
  "produces": {
    "type": "spread",
    "left_master": "J-Half",
    "right_master": "J-Half"
  },
  "bind": {
    "left_master": {
      "halfphoto_1": "input.common_photos.half_class[$consumed_half_class]",
      "halfphoto_2": "input.common_photos.half_class[$consumed_half_class + 1]"
    },
    "right_master": {
      "halfphoto_1": "input.common_photos.half_class[$consumed_half_class + 2]",
      "halfphoto_2": "input.common_photos.half_class[$consumed_half_class + 3]"
    }
  },
  "consumes": {
    "common_photos": {
      "half_class": 4
    },
    "pages": 2,
    "mandatory_section": {
      "pages": 1
    }
  }
}
