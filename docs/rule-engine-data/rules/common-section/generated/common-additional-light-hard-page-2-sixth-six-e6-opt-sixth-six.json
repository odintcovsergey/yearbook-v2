{
  "id": "common-additional-light-hard-page-2-sixth-six-e6-opt-sixth-six",
  "family_id": "common-section",
  "family_version": "1.0",
  "priority": 213,
  "display_name": "Общий раздел (дополнительный): Лайт плотные, страница 2 — коллаж 12 фото 1/6 (опция sixth-six)",
  "description": "Авто-сгенерировано из docs/templates/album-structure-matrix.json entry #6 (РЭ.20.6.3). Матрица: light × hard, students [{\"min\":1,\"max\":12},{\"min\":22,\"max\":24}]. additional_section_pages[2] = sixth_six. Эта опция выбрана из alternative по приоритету наличия фотоматериала.",
  "when": {
    "preset_density": "light",
    "preset_sheet_type": "hard",
    "students_count": {
      "between": [
        1,
        24
      ]
    },
    "common_photos.sixth.count": {
      "gte": 12
    }
  },
  "produces": {
    "type": "spread",
    "left_master": "J-Collage-6",
    "right_master": "J-Collage-6"
  },
  "bind": {
    "left_master": {
      "collagephoto_{i}": {
        "template": "input.common_photos.sixth[$consumed_sixth + {i} - 1]",
        "params": {
          "i": {
            "range": [
              1,
              6
            ]
          }
        }
      }
    },
    "right_master": {
      "collagephoto_{i}": {
        "template": "input.common_photos.sixth[$consumed_sixth + 6 + {i} - 1]",
        "params": {
          "i": {
            "range": [
              1,
              6
            ]
          }
        }
      }
    }
  },
  "consumes": {
    "common_photos": {
      "sixth": 12
    },
    "pages": 2
  }
}
