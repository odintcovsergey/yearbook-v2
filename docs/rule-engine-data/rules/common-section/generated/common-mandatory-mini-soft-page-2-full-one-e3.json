{
  "id": "common-mandatory-mini-soft-page-2-full-one-e3",
  "family_id": "common-section",
  "family_version": "1.0",
  "priority": 231,
  "display_name": "Общий раздел (обязательный): Мини мягкие, страница 2 — 2 общих фото класса",
  "description": "Авто-сгенерировано из docs/templates/album-structure-matrix.json entry #3 (РЭ.20.6.3). Матрица: mini × soft, students [{\"min\":1,\"max\":24}]. mandatory_section_pages[2] = full_one.",
  "when": {
    "preset_density": "mini",
    "preset_sheet_type": "soft",
    "students_count": {
      "between": [
        1,
        24
      ]
    },
    "mandatory_section.current_index": 2,
    "common_photos.full_class.count": {
      "gte": 2
    }
  },
  "produces": {
    "type": "spread",
    "left_master": "J-Full",
    "right_master": "J-Full"
  },
  "bind": {
    "left_master": {
      "classphotoframe": "input.common_photos.full_class[$consumed_full_class]"
    },
    "right_master": {
      "classphotoframe": "input.common_photos.full_class[$consumed_full_class + 1]"
    }
  },
  "consumes": {
    "common_photos": {
      "full_class": 2
    },
    "pages": 2,
    "mandatory_section": {
      "pages": 1
    }
  }
}
