{
  "id": "common-mandatory-medium-hard-page-5-half-pair-e14",
  "family_id": "common-section",
  "family_version": "1.0",
  "priority": 232,
  "display_name": "Общий раздел (обязательный): Медиум плотные, страница 5 — пара 1/2 класса",
  "description": "Авто-сгенерировано из docs/templates/album-structure-matrix.json entry #14 (РЭ.20.6.3). Матрица: medium × hard, students [{\"min\":7,\"max\":8},{\"min\":15,\"max\":16},{\"min\":23,\"max\":24},{\"min\":31,\"max\":32}]. mandatory_section_pages[5] = half_pair.",
  "when": {
    "preset_density": "medium",
    "preset_sheet_type": "hard",
    "students_count": {
      "between": [
        7,
        32
      ]
    },
    "mandatory_section.current_index": 5,
    "common_photos.half_class.count": {
      "gte": 4
    }
  },
  "produces": {
    "type": "spread",
    "left_master": "J-Half",
    "right_master": "J-Half"
  },
  "bind": {
    "left_master": {
      "halfphoto_1": "input.common_photos.half_class[$consumed_half_class]",
      "halfphoto_2": "input.common_photos.half_class[$consumed_half_class + 1]"
    },
    "right_master": {
      "halfphoto_1": "input.common_photos.half_class[$consumed_half_class + 2]",
      "halfphoto_2": "input.common_photos.half_class[$consumed_half_class + 3]"
    }
  },
  "consumes": {
    "common_photos": {
      "half_class": 4
    },
    "pages": 2,
    "mandatory_section": {
      "pages": 1
    }
  }
}
