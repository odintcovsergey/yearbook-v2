{
  "id": "student-section-medium-overflow",
  "family_id": "student-section",
  "family_version": "1.0",
  "priority": 200,
  "display_name": "Medium: полный разворот 4+4 (overflow)",
  "description": "density=medium, остаток >= 9: разворот M-Grid-Page слева (4 портрета) + M-Grid-Page справа (следующие 4). Потребляет 8.",
  "when": {
    "section.density": "medium",
    "students_remaining": { "gte": 9 }
  },
  "produces": {
    "type": "spread",
    "left_master": "M-Grid-Page",
    "right_master": "M-Grid-Page"
  },
  "bind": {
    "left_master": {
      "studentportrait_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].portrait",
        "params": { "i": { "range": [1, 4] } }
      },
      "studentname_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].full_name",
        "params": { "i": { "range": [1, 4] } }
      },
      "studentquote_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].quote",
        "params": { "i": { "range": [1, 4] } },
        "skip_if": "!section.has_quote"
      }
    },
    "right_master": {
      "studentportrait_{i}": {
        "template": "input.students[$current_student_index + 4 + {i} - 1].portrait",
        "params": { "i": { "range": [1, 4] } }
      },
      "studentname_{i}": {
        "template": "input.students[$current_student_index + 4 + {i} - 1].full_name",
        "params": { "i": { "range": [1, 4] } }
      },
      "studentquote_{i}": {
        "template": "input.students[$current_student_index + 4 + {i} - 1].quote",
        "params": { "i": { "range": [1, 4] } },
        "skip_if": "!section.has_quote"
      }
    }
  },
  "consumes": { "students": 8 }
}
