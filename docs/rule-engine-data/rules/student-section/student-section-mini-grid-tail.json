{
  "id": "student-section-mini-grid-tail",
  "family_id": "student-section",
  "family_version": "1.0",
  "priority": 90,
  "display_name": "Mini: одностраничная Grid (хвост 1..12)",
  "description": "density=mini, остаток 1..12: N-Grid-Page на одной (левой) странице с балансировкой. Правая страница 'висит' для общего раздела (J-*). Срабатывает как для хвоста после overflow, так и для изначально маленьких классов.",
  "when": {
    "section.density": "mini",
    "students_remaining": { "between": [1, 12] }
  },
  "produces": {
    "type": "page",
    "side": "left",
    "master": "N-Grid-Page"
  },
  "bind": {
    "N-Grid-Page": {
      "studentportrait_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].portrait",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "studentname_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].full_name",
        "params": { "i": { "range": [1, "students_remaining"] } }
      }
    }
  },
  "consumes": { "students": "students_remaining" },
  "balance": { "placeholder_centering": true, "hide_unfilled": true }
}
