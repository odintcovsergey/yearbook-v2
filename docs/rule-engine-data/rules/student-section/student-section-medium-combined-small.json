{
  "id": "student-section-medium-combined-small",
  "family_id": "student-section",
  "family_version": "1.0",
  "priority": 100,
  "display_name": "Medium: маленький остаток + общее фото (Combined)",
  "description": "density=medium, остаток 1..2 + есть общее фото: M-Combined-Page (до 2 портретов + 1 общее фото). Маленький остаток + общее фото — типовой случай для last page.",
  "when": {
    "section.density": "medium",
    "students_remaining": { "between": [1, 2] },
    "common_photos.full_class.count": { "gte": 1 }
  },
  "produces": {
    "type": "page",
    "side": "any",
    "master": "M-Combined-Page"
  },
  "bind": {
    "M-Combined-Page": {
      "studentportrait_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].portrait",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "studentname_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].full_name",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "studentquote_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].quote",
        "params": { "i": { "range": [1, "students_remaining"] } },
        "skip_if": "!section.has_quote"
      },
      "classphotoframe": "input.common_photos.full_class[$consumed_full_class]"
    }
  },
  "consumes": {
    "students": "students_remaining",
    "common_photos": { "full_class": 1 }
  },
  "balance": { "placeholder_centering": true, "hide_unfilled": true }
}
