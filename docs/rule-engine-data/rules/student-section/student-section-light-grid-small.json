{
  "id": "student-section-light-grid-small",
  "family_id": "student-section",
  "family_version": "1.0",
  "priority": 50,
  "display_name": "Light: маленький остаток без общего фото (Grid)",
  "description": "density=light, остаток 1..3 + НЕТ общего фото: L-Grid-Page на одной странице с балансировкой (1..3 портрета). Combined-вариант не применим без общего фото. Срабатывает с приоритетом 50 (ниже чем combined-small 100), значит когда есть общее — выбирается Combined, иначе — этот fallback.",
  "when": {
    "section.density": "light",
    "students_remaining": { "between": [1, 3] }
  },
  "produces": {
    "type": "page",
    "side": "left",
    "master": "L-Grid-Page"
  },
  "bind": {
    "L-Grid-Page": {
      "studentportrait_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].portrait",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "studentname_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].full_name",
        "params": { "i": { "range": [1, "students_remaining"] } }
      }
    }
  },
  "consumes": { "students": "students_remaining" },
  "balance": { "placeholder_centering": true, "hide_unfilled": true }
}
