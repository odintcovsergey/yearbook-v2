{
  "id": "student-section-light-grid-tail",
  "family_id": "student-section",
  "family_version": "1.0",
  "priority": 90,
  "display_name": "Light: одностраничная Grid (хвост 1..6)",
  "description": "density=light, остаток 1..6: L-Grid-Page на одной (левой) странице с балансировкой. Правая страница 'висит' для следующей секции (общий раздел common-section заполнит J-Half/J-Full/J-Collage-6). Срабатывает как для хвоста после overflow (например 13 учеников → 6+6 + здесь 1), так и для изначально маленьких классов (1..6 без общего фото).",
  "when": {
    "section.density": "light",
    "students_remaining": { "between": [1, 6] }
  },
  "produces": {
    "type": "page",
    "side": "left",
    "master": "L-Grid-Page"
  },
  "bind": {
    "L-Grid-Page": {
      "studentportrait_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].portrait",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "studentname_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].full_name",
        "params": { "i": { "range": [1, "students_remaining"] } }
      }
    }
  },
  "consumes": { "students": "students_remaining" },
  "balance": { "placeholder_centering": true, "hide_unfilled": true }
}
