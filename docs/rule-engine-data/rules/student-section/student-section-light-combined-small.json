{
  "id": "student-section-light-combined-small",
  "family_id": "student-section",
  "family_version": "1.0",
  "priority": 100,
  "display_name": "Light: маленький остаток + общее фото (Combined)",
  "description": "density=light, остаток 1..3 + есть общее фото класса: L-Combined-Page (до 3 портретов + 1 общее фото внизу). Маленький остаток + общее фото — типовой случай для last page вёрстки.",
  "when": {
    "section.density": "light",
    "students_remaining": { "between": [1, 3] },
    "common_photos.full_class.count": { "gte": 1 }
  },
  "produces": {
    "type": "page",
    "side": "any",
    "master": "L-Combined-Page"
  },
  "bind": {
    "L-Combined-Page": {
      "studentportrait_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].portrait",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "studentname_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].full_name",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "classphotoframe": "input.common_photos.full_class[$consumed_full_class]"
    }
  },
  "consumes": {
    "students": "students_remaining",
    "common_photos": { "full_class": 1 }
  },
  "balance": { "placeholder_centering": true, "hide_unfilled": true }
}
