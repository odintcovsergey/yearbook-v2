{
  "id": "student-section-mini-initial-combined",
  "family_id": "student-section",
  "family_version": "1.0",
  "priority": 95,
  "display_name": "Mini: изначально маленький класс + общее фото (Combined)",
  "description": "density=mini, изначально 1..4 ученика + есть общее фото: N-Combined-Page (до 4 портретов + общее). НЕ для хвоста после overflow.",
  "when": {
    "section.density": "mini",
    "students_remaining": { "between": [1, 4] },
    "current_student_index": 0,
    "common_photos.full_class.count": { "gte": 1 }
  },
  "produces": {
    "type": "page",
    "side": "any",
    "master": "N-Combined-Page"
  },
  "bind": {
    "N-Combined-Page": {
      "studentportrait_{i}": {
        "template": "input.students[{i} - 1].portrait",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "studentname_{i}": {
        "template": "input.students[{i} - 1].full_name",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "classphotoframe": "input.common_photos.full_class[0]"
    }
  },
  "consumes": {
    "students": "students_remaining",
    "common_photos": { "full_class": 1 }
  },
  "balance": { "placeholder_centering": true, "hide_unfilled": true }
}
