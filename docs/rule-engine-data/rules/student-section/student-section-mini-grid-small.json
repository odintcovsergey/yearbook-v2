{
  "id": "student-section-mini-grid-small",
  "family_id": "student-section",
  "family_version": "1.0",
  "priority": 50,
  "display_name": "Mini: маленький остаток без общего фото (Grid)",
  "description": "density=mini, остаток 1..4 + НЕТ общего фото: N-Grid-Page на левой странице с балансировкой.",
  "when": {
    "section.density": "mini",
    "students_remaining": { "between": [1, 4] }
  },
  "produces": {
    "type": "page",
    "side": "left",
    "master": "N-Grid-Page"
  },
  "bind": {
    "N-Grid-Page": {
      "studentportrait_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].portrait",
        "params": { "i": { "range": [1, "students_remaining"] } }
      },
      "studentname_{i}": {
        "template": "input.students[$current_student_index + {i} - 1].full_name",
        "params": { "i": { "range": [1, "students_remaining"] } }
      }
    }
  },
  "consumes": { "students": "students_remaining" },
  "balance": { "placeholder_centering": true, "hide_unfilled": true }
}
